;; grammar.edn — GIF header + Logical Screen Descriptor as EDN data
;; (little-endian). R0 reads canvas dims; frame counting + LZW pixel decode
;; are done in gif.core.
{:meta {:id :gif :endian :little :root :gif-file}
 :types
 {:gif-file
  [{:id :magic  :type :str :size 6}                      ; "GIF87a" / "GIF89a" (validated in code)
   {:id :width  :type :u16}
   {:id :height :type :u16}
   {:id :flags  :type :u8}                               ; GCT present / color resolution / sort / GCT size
   {:id :bg     :type :u8}
   {:id :aspect :type :u8}]}}
